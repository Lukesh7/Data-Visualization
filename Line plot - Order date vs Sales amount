import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns

#Reading csv
df = pd.read_csv('sales_data_practice.csv')
#Order_ID,Product,Region,Sales_Amount,Order_Date
#Converting to_datetime
df['Order_Date'] = pd.to_datetime(df['Order_Date'])

#1.Create a line plot for order_date vs sales amount
#Line plot - Order_Date vs Sales_Amount
df = df.sort_values('Order_Date') #Sorting Dates
plt.figure(figsize=(8,5))
plt.plot(df['Order_Date'], df['Sales_Amount'], marker="o")
plt.title('Line plot - Order Date VS Sales amount')
plt.xlabel('Order  Date')
plt.ylabel('Sales amount')
plt.xticks(rotation=45)
plt.grid()
plt.show()
